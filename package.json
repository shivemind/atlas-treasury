{
  "name": "@atlas/treasury",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3004",
    "build": "prisma generate && next build",
    "start": "next start --port 3004",
    "lint": "eslint .",
    "test": "prisma generate && vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "openapi:validate": "node scripts/openapi-validate.mjs",
    "openapi:lint": "spectral lint openapi/openapi.yaml",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@prisma/client": "^6.16.0",
    "@upstash/redis": "^1.36.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "prisma"]
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.14.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "prisma": "^6.16.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}

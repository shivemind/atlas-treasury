# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/atlas_treasury?schema=public"

# ── Service Port ─────────────────────────────────────────────────────
PORT=3004

# ── Upstash Redis (rate limiting & idempotency cache) ────────────────
REDIS_REST_URL=
REDIS_REST_TOKEN=

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Idempotency ─────────────────────────────────────────────────────
IDEMPOTENCY_TTL_SECONDS=86400

# ── Webhook Retry ────────────────────────────────────────────────────
WEBHOOK_RETRY_BASE_SECONDS=30
WEBHOOK_RETRY_MAX_SECONDS=3600

# ── Cron ─────────────────────────────────────────────────────────────
CRON_SECRET=
